{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenFusion",
  "version": "0.0.1",
  "identifier": "net.originlayer.openfusion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenFusion",
        "width": 1024,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/openfusion-engine"],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}
